# ============================================
# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit the .env file to GitHub
# ============================================

# ============================================
# MongoDB Configuration
# ============================================
# Get your MongoDB URI from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/assessment_db


# ============================================
# Google Gemini API Configuration
# ============================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# ============================================
# Flask Configuration
# ============================================
# Generate a secure secret key using: python -c "import secrets; print(secrets.token_hex(32))"
# Replace the example below with a randomly generated key
SECRET_KEY=your_randomly_generated_secret_key_here


# ============================================
# Admin Credentials (Optional but recommended)
# ============================================
# Note: Consider using more secure authentication methods in production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_secure_password
